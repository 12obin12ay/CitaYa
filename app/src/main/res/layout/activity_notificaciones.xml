<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_gradient"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- VOLVER -->
            <LinearLayout
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"

                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@android:color/white"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Volver"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- TITULO -->
            <TextView
                android:text="Notificaciones"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="40dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtResumen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 notificaciones nuevas"
                android:textColor="@android:color/white"
                android:textSize="18sp"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardRecordatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"

            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- CONTENIDO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- BARRA AZUL -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#2D7DD2"/>

                    <!-- CONTENIDO INTERNO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- ICONO -->
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_blue_light"

                            android:src="@drawable/ic_calendar"
                            app:tint="#2D7DD2"/>

                        <!-- TEXTO -->
                        <LinearLayout
                            android:layout_marginStart="10dp"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Recordatorio de cita"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:text="Tu cita con el Dr. Carlos Rodríguez es mañana a las 09:00 AM"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hace 2 horas"
                                android:textSize="13sp"
                                android:textColor="#999"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- 🔴 PUNTO ROJO (AHORA ARRIBA DERECHA) -->
                <View
                    android:id="@+id/punto1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_dot_red"/>

            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <!-- CARD 2 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMensaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- CONTENIDO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- BARRA AZUL (solo si quieres) -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#2D7DD2"/>

                    <!-- CONTENIDO INTERNO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- ICONO CON FONDO -->
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_green_light"

                            android:src="@drawable/ic_consulta"
                            app:tint="#43A047"/>

                        <!-- TEXTO -->
                        <LinearLayout
                            android:layout_marginStart="10dp"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mensaje de la clínica"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:text="Recordamos que debe llegar 15 minutos antes de su cita"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hace 5 horas"
                                android:textSize="13sp"
                                android:textColor="#999"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- 🔴 PUNTO ARRIBA DERECHA -->
                <View
                    android:id="@+id/punto2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_dot_red"/>

            </FrameLayout>

        </androidx.cardview.widget.CardView>
        <!-- CARD 3 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"

            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- CONTENIDO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- BARRA AZUL (opcional si quieres solo en 2 primeras quítala aquí) -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#2D7DD2"/>

                    <!-- CONTENIDO INTERNO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- ICONO CON FONDO NARANJA -->
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_orange_light"

                            android:src="@drawable/ic_help"
                            app:tint="#FF9800"/>

                        <!-- TEXTO -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Resultado de análisis"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:text="Los resultados de tus análisis clínicos ya están disponibles"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hace 1 día"
                                android:textColor="#999"
                                android:textSize="13sp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- 🔴 PUNTO ROJO -->
                <View
                    android:id="@+id/punto3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_dot_red"/>

            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <!-- CARD 4 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"

            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- CONTENIDO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- ⚠️ SOLO SI QUIERES BORDE (si no, elimínalo) -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#2D7DD2"/>

                    <!-- CONTENIDO INTERNO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- ICONO CON FONDO VERDE -->
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_green_light"
                            android:src="@drawable/ic_check"
                            app:tint="#4CAF50"/>

                        <!-- TEXTO -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Cita confirmada"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:text="Tu cita con la Dra. María González ha sido confirmada para el 28 de Abril"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hace 2 días"
                                android:textSize="13sp"
                                android:textColor="#999"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- 🔴 PUNTO ROJO -->
                <View
                    android:id="@+id/punto4"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_dot_red"/>

            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <!-- CARD 5 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCitaprox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- CONTENIDO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- (OPCIONAL) BARRA AZUL -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#2D7DD2"/>

                    <!-- CONTENIDO INTERNO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- ICONO CON FONDO -->
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_blue_light"

                            android:src="@drawable/ic_calendar"
                            app:tint="#2D7DD2"/>

                        <!-- TEXTOS -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Próxima revisión"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:text="Es momento de agendar tu proximo chequeo anual"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hace 3 días"
                                android:textSize="14sp"
                                android:textColor="#999"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- 🔴 PUNTO ROJO -->
                <View
                    android:id="@+id/punto5"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_dot_red"/>

            </FrameLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>