<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_gradient">

            <LinearLayout
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@android:color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Volver"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reservar cita"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elige tu doctor y horario"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doctores disponibles"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="10dp"/>

            <!-- DOCTOR 1 -->
            <LinearLayout
                android:id="@+id/doc1"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_normal"
                android:padding="12dp"
                android:layout_marginBottom="10dp"
                android:elevation="3dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/doctor"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dr. Carlos Rodríguez"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cardiología"
                        android:textColor="#2D7DD2"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 4.9 • 15 años"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/check1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    app:tint="#4CAF50"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- DOCTOR 2 -->
            <LinearLayout
                android:id="@+id/doc2"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_normal"
                android:padding="12dp"
                android:layout_marginBottom="10dp"
                android:elevation="3dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/doctora"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dra. María González"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Medicina General"
                        android:textColor="#2D7DD2"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 4.8 • 12 años"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/check2"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    app:tint="#4CAF50"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- DOCTOR 3 -->
            <LinearLayout
                android:id="@+id/doc3"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_normal"
                android:padding="12dp"
                android:layout_marginBottom="10dp"
                android:elevation="3dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/doctor"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dr. Luis Mendoza"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pediatría"
                        android:textColor="#2D7DD2"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 5 • 18 años"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/check3"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    app:tint="#4CAF50"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- DOCTOR 4 -->
            <LinearLayout
                android:id="@+id/doc4"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_normal"
                android:padding="12dp"
                android:elevation="3dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/doctora"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dra. Ana Fernández"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dermatología"
                        android:textColor="#2D7DD2"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 4.7 • 10 años"/>
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/check4"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    app:tint="#4CAF50"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- FECHA -->
            <LinearLayout
                android:id="@+id/layoutFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecciona la fecha"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etFecha"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:hint="dd/mm/aaaa"
                    android:focusable="false"
                    android:clickable="true"/>
            </LinearLayout>
            <!-- HORARIOS -->
            <LinearLayout
                android:id="@+id/layoutHorarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Horarios disponibles"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"/>

                <!-- FILA 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/hora1"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 09:00"
                        android:background="@drawable/bg_hora_normal"/>

                    <TextView
                        android:id="@+id/hora2"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 10:00"
                        android:background="@drawable/bg_hora_normal"/>

                    <TextView
                        android:id="@+id/hora3"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 11:00"
                        android:background="@drawable/bg_hora_normal"/>
                </LinearLayout>

                <!-- FILA 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/hora4"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 13:00"
                        android:background="@drawable/bg_hora_normal"/>

                    <TextView
                        android:id="@+id/hora5"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 14:00"
                        android:background="@drawable/bg_hora_normal"/>

                    <TextView
                        android:id="@+id/hora6"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 15:00"
                        android:background="@drawable/bg_hora_normal"/>
                </LinearLayout>

                <!-- FILA 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/hora7"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 16:00"
                        android:background="@drawable/bg_hora_normal"/>

                    <TextView
                        android:id="@+id/hora8"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 17:00"
                        android:background="@drawable/bg_hora_normal"/>

                    <TextView
                        android:id="@+id/hora9"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:gravity="center"
                        android:text="🕒 18:00"
                        android:background="@drawable/bg_hora_normal"/>
                </LinearLayout>

            </LinearLayout>

            <!-- BOTÓN -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Confirmar cita"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:textSize="18dp"
                app:backgroundTint="#43A047"
                app:cornerRadius="12dp"

                app:icon="@drawable/ic_calendar"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@android:color/white"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>