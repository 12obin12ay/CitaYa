<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:layout_editor_absoluteX="7dp"
    tools:layout_editor_absoluteY="21dp">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_gradient"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- VOLVER -->

        <!-- TITULO -->

        <!-- SUBTITULO -->

        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:text="Mis citas"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:text="Historial de consultas"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtTitulo" />

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@android:color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Volver"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/tabs"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="-40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp">

            <!-- BOTÓN ACTIVO -->
            <TextView
                android:id="@+id/tabProximas"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_tab_selected"
                android:gravity="center"
                android:text="Próximas"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>

            <!-- BOTÓN INACTIVO -->
            <TextView
                android:id="@+id/tabAnteriores"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:gravity="center"
                android:text="Anteriores"
                android:textColor="#6B6B6B"
                android:textStyle="bold"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- CONTENEDOR GENERAL -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 🔵 PROXIMAS -->
        <LinearLayout
            android:id="@+id/layoutProximas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- CARD 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView android:text="Dr. Carlos Rodríguez" android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Cardiología" android:textColor="#2D7DD2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="22 Abril 2026"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="09:00 AM"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Consultorio 100"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Confirmada" android:textColor="#4CAF50"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView android:text="Dra. María González" android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Medicina General" android:textColor="#2D7DD2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="28 Abr 2026"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="14:00 PM"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Consultorio 101"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Pendiente" android:textColor="#FF9800"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- 🟣 ANTERIORES -->
        <LinearLayout
            android:id="@+id/layoutAnteriores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView android:text="Dr. Pedro López" android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Dermatología" android:textColor="#2D7DD2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="10 Marzo 2026"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="10:00 AM"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Consultorio 200"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:text="Completada" android:textColor="#4CAF50"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>