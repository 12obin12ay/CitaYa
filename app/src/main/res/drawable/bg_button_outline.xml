<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESIONADO -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2D7DD2"/> <!-- azul -->
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- NORMAL -->
    <item>
        <shape>
            <solid android:color="#FFFFFF"/> <!-- 🔥 BLANCO -->
            <stroke
                android:width="2dp"
                android:color="#2D7DD2"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

</selector>